generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id        String   @id @default(uuid())
  name      String   @unique
  domain    String   @unique // e.g. college.edu
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config        CollegeConfig?
  users         User[]
  clubs         Club[]
  events        Event[]
  sponsors      Sponsor[]
  transactions  Transaction[]
  tasks         Task[]
  invitations   Invitation[]
  clubMembers   ClubMember[]
  registrations Registration[]
  contracts     CollegeContract[]
  blockchainActivities BlockchainActivity[]
  governanceProposals GovernanceProposal[]
}

model CollegeConfig {
  id               String   @id @default(uuid())
  collegeId        String   @unique
  college          College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  treasuryContract String?  // Algorand smart contract app id
  treasuryAppId    String?
  treasuryAddress  String?
  entryTokenAssetId String?
  soulboundAssetId String?
  entryTokenMinterAppId String? // Added for Entry Token syncing
  attendancePoPAppId   String? // Added for PoP attendance guarding
  governanceAppId     String? // Added for Governance guarding
  algorandNetwork  AlgorandNetwork @default(TESTNET)
  algodUrl         String?
  indexerUrl       String?
  brandingColor    String?
  brandingLogo     String?
}

enum AlgorandNetwork {
  TESTNET
  LOCALNET
}

enum CollegeContractType {
  TREASURY
  ENTRY_TOKEN
  SOULBOUND
}

enum BlockchainActionType {
  DEPLOY
  TREASURY_LOG
  MINT
  VOTE
  RELEASE
}

enum BlockchainSyncStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum Role {
  ADMIN
  COORDINATOR
  PRESIDENT
  VP
  MEMBER
  GUEST
}

model User {
  id              String         @id @default(uuid())
  name            String
  email           String         @unique
  passwordHash    String
  
  studentId       String?   @unique
  department      String?
  year            Int?

  inviteToken     String?
  inviteTokenExpiry DateTime?
  isVerified      Boolean        @default(false)

  role            Role           @default(MEMBER)
  walletAddress   String?        // Pera Wallet address
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  collegeId       String
  college         College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  // Relationships
  coordinatedClubs Club[]        @relation("CoordinatorClubs")
  presidencies     Club[]        @relation("PresidentClubs")
  vpClubs          Club[]        @relation("VPClubs")
  memberships      ClubMember[]
  registrations    Registration[]
  assignedTasks    Task[]        @relation("AssignedTo")
  receivedInvitations Invitation[]
  governanceProposals GovernanceProposal[]

  @@index([collegeId])
}

enum ClubStatus {
  PENDING
  ACTIVE
  INACTIVE
}

model Club {
  id               String       @id @default(uuid())
  name             String       @unique
  description      String
  category         String
  status           ClubStatus   @default(PENDING)
  approvalRemarks  String?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  prizePoolBalance Float        @default(0.0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  collegeId        String
  college          College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  // Relationships
  coordinatorId    String?
  coordinator      User?        @relation("CoordinatorClubs", fields: [coordinatorId], references: [id])
  presidentId      String?
  president        User?        @relation("PresidentClubs", fields: [presidentId], references: [id])
  vpId             String?
  vp               User?        @relation("VPClubs", fields: [vpId], references: [id])

  members          ClubMember[]
  events           Event[]
  sponsors         Sponsor[]
  transactions     Transaction[]
  tasks            Task[]
  invitations      Invitation[]
  proposals        GovernanceProposal[]

  @@index([collegeId])
}

model ClubMember {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clubId     String
  club       Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  customRole String?  // e.g. "Treasurer", "Event Head"
  joinedAt   DateTime @default(now())

  collegeId  String
  college    College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([collegeId])
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  CONCLUDED
}

model Event {
  id           String       @id @default(uuid())
  title        String
  description  String
  category     String?
  date         DateTime
  venue        String
  capacity     Int
  budget       Float        @default(0.0)
  status       EventStatus  @default(PENDING)
  approvalRemarks String?
  approvedAt   DateTime?
  rejectedAt   DateTime?
  isPublic     Boolean      @default(false)
  posterPrompt String?
  posterImageUrl String?
  treasuryPlaceholderTxId String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  collegeId    String
  college      College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  // Relationships
  clubId       String
  club         Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  
  registrations Registration[]
  transactions  Transaction[]
  tasks         Task[]
  proposals     GovernanceProposal[]

  @@index([collegeId])
}

model Registration {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  isWaitlisted   Boolean  @default(false)
  attended       Boolean  @default(false)
  qrCode         String?  @unique
  certificateUrl String?
  registeredAt   DateTime @default(now())

  collegeId      String
  college        College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([collegeId])
}

enum SponsorStatus {
  PROSPECT
  CONTACTED
  NEGOTIATING
  CONFIRMED
  DECLINED
}

model Sponsor {
  id             String        @id @default(uuid())
  name           String
  organization   String
  email          String?
  phone          String?
  status         SponsorStatus @default(PROSPECT)
  outreachDraft  String?
  lastContactedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  collegeId      String
  college        College       @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  // Relationships
  clubId         String
  club           Club          @relation(fields: [clubId], references: [id], onDelete: Cascade)
  transactions   Transaction[]

  @@index([collegeId])
}

enum TransactionType {
  CREDIT
  DEBIT
}

model Transaction {
  id             String          @id @default(uuid())
  amount         Float
  type           TransactionType
  description    String
  date           DateTime        @default(now())
  
  txnHash        String?         @unique // Algorand Testnet Transaction Hash
  walletAddress  String?
  blockchainActivityId String?   @unique
  
  collegeId      String
  college        College         @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  // Relationships
  clubId         String
  club           Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  eventId        String?
  event          Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  sponsorId      String?
  sponsor        Sponsor?        @relation(fields: [sponsorId], references: [id], onDelete: Cascade)
  blockchainActivity BlockchainActivity? @relation(fields: [blockchainActivityId], references: [id], onDelete: SetNull)

  @@index([collegeId])
}

model CollegeContract {
  id           String              @id @default(uuid())
  collegeId    String
  college      College             @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  type         CollegeContractType
  network      AlgorandNetwork
  appId        String?
  assetId      String?
  address      String?
  deployedTxId String?
  note         String?
  metadata     Json?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  activities   BlockchainActivity[]

  @@unique([collegeId, type, network])
  @@index([collegeId])
}

model BlockchainActivity {
  id           String              @id @default(uuid())
  collegeId    String
  college      College             @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  contractId   String?
  contract     CollegeContract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)
  action       BlockchainActionType
  txId         String              @unique
  walletAddress String?
  note         String?
  status       BlockchainSyncStatus @default(CONFIRMED)
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  transaction  Transaction?

  @@index([collegeId])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum GovernanceProposalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  EXECUTED
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String
  deadline    DateTime?
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  createdAt   DateTime     @default(now())

  collegeId   String
  college     College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  // Relationships
  clubId      String
  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  assigneeId  String
  assignee    User         @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model GovernanceProposal {
  id          String                   @id @default(uuid())
  title       String
  description String
  status      GovernanceProposalStatus @default(DRAFT)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  collegeId   String
  college     College                  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  clubId      String
  club        Club                     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  eventId     String
  event       Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proposerId  String
  proposer    User                     @relation(fields: [proposerId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@index([eventId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Invitation {
  id         String           @id @default(uuid())
  clubId     String
  club       Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status     InvitationStatus @default(PENDING)
  customRole String?
  createdAt  DateTime         @default(now())

  collegeId  String
  college    College          @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([collegeId])
}
